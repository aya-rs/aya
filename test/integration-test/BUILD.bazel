load("@bazel_lib//lib:copy_to_directory.bzl", "copy_to_directory")
load("@crates//:defs.bzl", "all_crate_deps")
load("//bazel:defs.bzl", "BPF_C_TARGET_ARCH", "aya_c_bpf_objects", "aya_rust_crate")
load("//bazel:vm.bzl", "aya_initramfs", "aya_qemu_vm_test")

C_BPF_OBJECTS = [
    ("bpf/ext.bpf.c", False),
    ("bpf/iter.bpf.c", True),
    ("bpf/main.bpf.c", False),
    ("bpf/multimap-btf.bpf.c", False),
    ("bpf/ringbuf-btf.bpf.c", True),
    ("bpf/enum_signed_32_checked_variants_reloc.bpf.c", True),
    ("bpf/enum_signed_32_reloc.bpf.c", True),
    ("bpf/enum_signed_64_checked_variants_reloc.bpf.c", True),
    ("bpf/enum_signed_64_reloc.bpf.c", True),
    ("bpf/enum_unsigned_32_checked_variants_reloc.bpf.c", True),
    ("bpf/enum_unsigned_32_reloc.bpf.c", True),
    ("bpf/enum_unsigned_64_checked_variants_reloc.bpf.c", True),
    ("bpf/enum_unsigned_64_reloc.bpf.c", True),
    ("bpf/field_reloc.bpf.c", True),
    ("bpf/pointer_reloc.bpf.c", True),
    ("bpf/struct_flavors_reloc.bpf.c", True),
    ("bpf/text_64_64_reloc.c", False),
    ("bpf/variables_reloc.bpf.c", False),
]

aya_c_bpf_objects(
    name = "c_bpf_objects",
    hdrs = [
        "bpf/reloc.h",
        "bpf/struct_with_scalars.h",
    ],
    objects = C_BPF_OBJECTS,
    target_arch = BPF_C_TARGET_ARCH,
    vmlinux = "@crates//:libbpf-sys-vmlinux-h-1.7.0+v1.7.0",
    deps = ["@libbpf"],
)

copy_to_directory(
    name = "bpf_out_dir",
    srcs = [
        ":c_bpf_objects",
        "//test/integration-ebpf:bpfel",
    ],
    root_paths = [
        ".",
        "test/integration-ebpf",
    ],
)

TEST_DEPS = [
    "//test/integration-common:integration-common-user" if dep == "//test/integration-common" else dep
    for dep in all_crate_deps(
        normal = True,
        normal_dev = True,
    )
]

aya_rust_crate(
    name = "integration-test",
    build_script = False,
    compile_data = [":bpf_out_dir"],
    rustc_env = {
        "OUT_DIR": "$(execpath :bpf_out_dir)",
    },
    test_deps = TEST_DEPS,
    unit_test_binary = True,
)

aya_initramfs(
    name = "vm_initramfs",
    srcs = [
        "//test/kernel:aya_kernel_config",
        "//test/kernel:aya_kernel_system_map",
        "//test-distro:init",
        "//test-distro:modprobe",
        ":integration-test-unit-test-bin",
    ],
    tests = ["integration-test-unit-test-bin"],
)

aya_qemu_vm_test(
    name = "vm_x86_64",
    timeout = "long",
    args = ["--test-threads=1"],
    initrd = ":vm_initramfs",
    kernel = "//test/kernel:aya_kernel",
    qemu_system_target = "x86_64",
    tags = [
        "qemu",
        "x86_64",
    ],
    target_compatible_with = ["@platforms//os:linux"],
)

aya_qemu_vm_test(
    name = "vm_aarch64",
    timeout = "long",
    args = ["--test-threads=1"],
    initrd = ":vm_initramfs",
    kernel = "//test/kernel:aya_kernel",
    qemu_system_target = "aarch64",
    tags = [
        "aarch64",
        "qemu",
    ],
    target_compatible_with = ["@platforms//os:linux"],
)
