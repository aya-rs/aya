# This file is the KCONFIG_ALLCONFIG request fragment for the aarch64
# integration VM, not the resolved Linux .config. See README.md for the command
# that generates the resolved .config.

# Boot, initramfs, and the qemu serial console.
CONFIG_64BIT = y
CONFIG_ARM64 = y
CONFIG_BINFMT_ELF = y
CONFIG_BLK_DEV_INITRD = y
CONFIG_DEVTMPFS = y
CONFIG_DEVTMPFS_MOUNT = y
CONFIG_PRINTK = y
CONFIG_PROC_FS = y
CONFIG_PROC_SYSCTL = y
CONFIG_SYSFS = y
CONFIG_TMPFS = y
CONFIG_TTY = y
CONFIG_UNIX = y

CONFIG_SERIAL_AMBA_PL011 = y
CONFIG_SERIAL_AMBA_PL011_CONSOLE = y

# Kernel symbol/config visibility used by tracing, stack, BTF, and feature tests.
CONFIG_DEBUG_KERNEL = y
CONFIG_DEBUG_FS = y
CONFIG_DEBUG_INFO = y
CONFIG_DEBUG_INFO_BTF = y
CONFIG_DEBUG_INFO_DWARF5 = y
CONFIG_FHANDLE = y
CONFIG_KALLSYMS = y
CONFIG_KALLSYMS_ALL = y
CONFIG_STACKTRACE = y

# Namespaces and cgroup v2.
CONFIG_CGROUPS = y
CONFIG_CGROUP_BPF = y
CONFIG_CGROUP_DEVICE = y
CONFIG_CGROUP_NET_CLASSID = y
CONFIG_CGROUP_NET_PRIO = y
CONFIG_EVENTFD = y
CONFIG_NAMESPACES = y
CONFIG_NET_NS = y
CONFIG_USER_NS = y

# Networking, loopback, tc, XDP, LWT, sk_reuseport, and netfilter BPF coverage.
CONFIG_INET = y
# Match the Debian kernels used by Cargo VM tests. CONFIG_IP_MULTIPLE_TABLES leaves
# RT_TABLE_LOCAL unallocated until an address is added, so inet_addr_type_table()
# returns RTN_BROADCAST while `lo` is down and bind(127.0.0.1) succeeds:
# https://github.com/torvalds/linux/blob/7d0a66e4bb9081d75c82ec4957c50034cb0ea449/net/ipv4/fib_frontend.c#L207-L240
# https://github.com/torvalds/linux/blob/7d0a66e4bb9081d75c82ec4957c50034cb0ea449/include/net/inet_sock.h#L442-L452
# CONFIG_IP_ADVANCED_ROUTER exposes CONFIG_IP_MULTIPLE_TABLES.
CONFIG_IP_ADVANCED_ROUTER = y
CONFIG_IP_MULTIPLE_TABLES = y
CONFIG_IPV6 = y
CONFIG_IPV6_SEG6_LWTUNNEL = y
CONFIG_LWTUNNEL = y
CONFIG_NET = y
CONFIG_NET_ACT_BPF = y
CONFIG_NET_CLS_ACT = y
CONFIG_NET_CLS_BPF = y
CONFIG_NET_CORE = y
CONFIG_NET_EGRESS = y
CONFIG_NET_INGRESS = y
CONFIG_NET_SCH_INGRESS = y
CONFIG_NET_SCHED = y
CONFIG_NETFILTER = y
CONFIG_NETDEVICES = y
CONFIG_PCI = y
CONFIG_XDP_SOCKETS = y
CONFIG_XFRM_USER = y
CONFIG_SYN_COOKIES = y

# BPF program/map coverage exercised by integration-test.
CONFIG_BPF = y
CONFIG_BPF_EVENTS = y
CONFIG_BPF_JIT = y
CONFIG_BPF_LSM = y
CONFIG_BPF_STREAM_PARSER = y
CONFIG_BPF_SYSCALL = y
CONFIG_BPF_UNPRIV_DEFAULT_OFF = n
CONFIG_KPROBES = y
CONFIG_KPROBE_EVENTS = y
CONFIG_PERF_EVENTS = y
CONFIG_FUNCTION_TRACER = y
CONFIG_SECURITY = y
CONFIG_SECURITY_NETWORK = y
CONFIG_SECURITYFS = y
CONFIG_SOCK_CGROUP_DATA = y
CONFIG_TRACING = y
# Aya tests use /sys/kernel/debug/tracing. Match distribution kernels that
# automount tracefs below debugfs for compatibility with that path.
CONFIG_TRACEFS_AUTOMOUNT_DEPRECATED = y
CONFIG_FTRACE = y
CONFIG_FTRACE_SYSCALLS = y
CONFIG_UPROBES = y
CONFIG_UPROBE_EVENTS = y

# Module core support provides modprobe_path and /proc/sys/kernel/modprobe.
# The initrd still keeps modules empty unless a test provides them explicitly.
CONFIG_MODULES = y
CONFIG_MODPROBE_PATH = "/sbin/modprobe"
